{
  "expo": {
    "name": "ATOM POS",
    "slug": "atom-pos",
    "version": "1.0.0",
    "scheme": "atom-pos",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-bg.jpg",
      "resizeMode": "cover",
      "backgroundColor": "#00B5A5"
    },
    "android": {
      "package": "com.atompos_k7x2.runable",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#00B5A5"
      },
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.atompos_k7x2.runable",
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "apiUrl": "https://atompos.up.railway.app/",
      "router": {},
      "eas": {
        "projectId": "e8993079-fe32-4f9f-95e2-44f17bbcb614"
      }
    },
    "owner": "axisxnor"
  }
}
